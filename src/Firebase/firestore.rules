// firestore.rules
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // ===========================================
    // HELPER FUNCTIONS
    // ===========================================
    
    function isAuthenticated() {
      return request.auth != null;
    }
    
    function getUserRole() {
      return get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role;
    }
    
    function isAdmin() {
      return isAuthenticated() && getUserRole() == 'admin';
    }
    
    function isStudent() {
      return isAuthenticated() && getUserRole() == 'student';
    }
    
    function isOwner(userId) {
      return isAuthenticated() && request.auth.uid == userId;
    }
    
    // ===========================================
    // USERS COLLECTION
    // ===========================================
    match /users/{userId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || userId == request.auth.uid;
    }
    
    // ===========================================
    // STUDENTS COLLECTION
    // ===========================================
    match /students/{studentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin() || studentId == request.auth.uid;
    }
    
    // ===========================================
    // ADMIN MASTER COLLECTIONS (prefixed with admin_)
    // ===========================================
    match /admin_{documentId} {
      allow read: if isAuthenticated();
      allow write: if isAdmin();
    }
    
    // ===========================================
    // STUDENT DERIVED COLLECTIONS (prefixed with student_)
    // ===========================================
    match /student_{documentId} {
      allow read: if isAuthenticated() && 
        (resource.data.studentId == request.auth.uid || isAdmin());
      allow write: if isStudent() && resource.data.studentId == request.auth.uid;
      allow create: if isStudent() && request.resource.data.studentId == request.auth.uid;
    }
    
    // ===========================================
    // SUBMISSIONS COLLECTION
    // ===========================================
    match /submissions/{documentId} {
      allow read: if isAuthenticated() && 
        (resource.data.studentId == request.auth.uid || isAdmin());
      allow create: if isStudent() && request.resource.data.studentId == request.auth.uid;
    }
    
    // ===========================================
    // LOOKUP COLLECTIONS (read-only for students)
    // ===========================================
    match /subjects { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /terms { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /academicYears { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /gradeDefinitions { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /periods { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /rooms { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /days { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /breaks { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /eventTypes { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /categories { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /audiences { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /priorities { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /paymentMethods { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /feeCategories { allow read: if isAuthenticated(); allow write: if isAdmin(); }
    match /fileTypes { allow read: if isAuthenticated(); allow write: if isAdmin(); }
  }
}